# ─── Gemini AI ──────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use (default: gemini-1.5-flash-8b)
GEMINI_MODEL=gemini-1.5-flash-8b

# ─── Supabase ────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Use the SERVICE ROLE key, never expose to frontend
SUPABASE_KEY=your_service_role_key_here

# ─── Deployment / CORS ───────────────────────────────────────────────
# Comma-separated list of allowed origins for the backend
ALLOWED_ORIGINS=http://localhost:3000

# ─── Donation Links (Frontend) ───────────────────────────────────────
# These are passed to the frontend build via docker-compose
NEXT_PUBLIC_KOFI_URL=https://ko-fi.com/yourhandle
NEXT_PUBLIC_UPI_ID=yourname@upi
NEXT_PUBLIC_UPI_NAME=Your Name
